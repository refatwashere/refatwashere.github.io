# Crypto backend `.htaccess` template
# Copy to: htdocs/crypto/backend/.htaccess

SetEnv ALLOWED_ORIGINS "https://refatishere.free.nf"
SetEnv API_TOKEN_CRYPTO "REPLACE_WITH_STRONG_CRYPTO_TOKEN"
SetEnv DB_HOST "REPLACE_DB_HOST"
SetEnv DB_USER "REPLACE_DB_USER"
SetEnv DB_PASS "REPLACE_DB_PASS"
SetEnv DB_NAME "REPLACE_DB_NAME"
