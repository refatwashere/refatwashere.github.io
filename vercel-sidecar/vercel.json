{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/planner",
      "dest": "/api/planner.js"
    }
  ],
  "env": {
    "PLANNER_SIDECAR_TOKEN": "@planner_sidecar_token"
  }
}